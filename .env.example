# System
PUID=<your PUID here>
PGID=<your PGID here>
TZ=<your TZ here>

# App
APP_URL=<your APP_URL here>
APP_KEY=<your APP_kEY here>
APP_PROXIES=<your docker network ranges here, eg:172.17.0.0/16,172.18.0.0/16,172.19.0.0/16>

# Database
DB_HOST=bookstack_db
DB_PORT=3306
DB_DATABASE=bookstack
DB_USERNAME=bookstack
DB_PASSWORD=<your DB_PASSWORD here>
MARIADB_ROOT_PASSWORD=<your MARIADB_ROOT_PASSWORD here>

BOOKSTACK_OIDC_CLIENT_ID=xxxxxxxx
BOOKSTACK_OIDC_CLIENT_SECRET=xxxxxxxx

BOOKSTACK_TENANT_ID=TENANT_ID

# Mail driver — SMTP
MAIL_DRIVER=smtp

# Point to your Postfix relay container (use service name if same Docker network)
MAIL_HOST_NAME=graph-mail-relay
MAIL_PORT=25

# No auth needed — Postfix is the one authenticating to Office365
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# From address — must match what your relay expects
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Bookstack Service"